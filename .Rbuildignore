# generated by configure; tracked templates are Makevars.in / Makevars.win.in
^src/Makevars$
^src/Makevars\.win$

# Rust build artifacts
^src/\.cargo$
^src/rust/target$
^src/rust/vendor$

# compiled output
^src/.*\.o$
^src/.*\.so$

# package-building infra (not for the installed package)
^tools/bench($|/)
^tools/config\.R$
^tools/msrv\.R$
^examples$

# pkgdown site
^docs$
^_pkgdown\.yml$

# project metadata / editor config
^\.github$
^\.vscode$
^\.zed$
^[.]?air[.]toml$
^justfile$
^README\.Rmd$
^LICENSE\.md$

# reference dumps from jiebaR / jieba-rs (not part of the package)
^jiebaR\.xml$
^jieba-rs\.xml$
